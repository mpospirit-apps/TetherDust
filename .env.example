# Copy this file to .env and fill in real values. .env is gitignored.
#   cp .env.example .env

# Fernet key for encrypting DB passwords and agent credentials.
# Must be 32 url-safe base64-encoded bytes. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TETHERDUST_ENCRYPTION_KEY=

# Django secret key (session signing, CSRF, etc.). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Shared secret authenticating filter registration (web/celery → mcp). Without
# it the MCP server's filter registration is unauthenticated. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_FILTER_SECRET=

# Shared secret authenticating Django → agent-gateway calls (codex/claude).
# Without it the gateways are unauthenticated. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_GATEWAY_SECRET=

# Shared secret authenticating the internal service API (tdmcp → backend). The
# MCP server's mutating tools (create_dashboard, add_chart, update_chart,
# save_tether_graph) send it as X-Service-Token. REQUIRED — without it the
# backend rejects every /api/internal/ call (it is a write API). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SERVICE_TOKEN=

# Django debug mode. Leave false for any real/exposed deployment — false turns on
# production hardening (secure cookies, HSTS, HTTPS redirect) and serves static
# via WhiteNoise, and assumes TLS is terminated in front of the app. For LOCAL
# development over plain HTTP set this to true (enables the dev server with
# auto-reload and relaxes the HTTPS-only hardening so http://localhost works).
DJANGO_DEBUG=false

# Comma-separated hosts/domains Django will serve. Set to your domain(s) in
# production, e.g. "tetherdust.example.com".
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL app database. Used by the `db` service and shared via connection
# strings to mcp, local-mcp, web, and celery.
DB_NAME=tetherdust
DB_USER=tetherdust
DB_PASSWORD=tetherdust

# Django superuser bootstrapped on first web startup.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost
